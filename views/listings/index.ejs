<% layout ("/layouts/boilerplate") %>
<body>

<div class="container">
  <div class="search-hero">
    <div class="hero-content">
      <h1>Find your next PG, no agent fees</h1>
      <p>No dalaal, no jhanjhat — seedha malik se baat.</p>
      
      <form action="/listings" method="GET">
        <div class="search-bar-wrap">
          <i class="fa-solid fa-location-dot"></i>
          <input type="search" name="location" class="form-control" placeholder="Search by area, college, or city..." value="<%= typeof searchLocation !== 'undefined' ? searchLocation : '' %>" />
          <button type="submit" class="btn-search">
            <i class="fa-solid fa-magnifying-glass"></i> Search
          </button>
        </div>
      </form>

      <div class="trust-chip-row">
        <span class="trust-chip">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
          Verified Properties
        </span>
        <span class="trust-chip">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
          Zero Brokerage
        </span>
        <span class="trust-chip">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a8 8 0 0 0-8 8c0 5.25 8 12 8 12s8-6.75 8-12a8 8 0 0 0-8-8z"></path><circle cx="12" cy="10" r="3"></circle></svg>
          Direct Owner Connect
        </span>
      </div>
    </div>

    <div class="hero-photo-wrap">
      <img src="https://images.unsplash.com/photo-1522202176988-66273c2fd55f?q=80&w=1200" alt="Comfortable Shared Student Living" />
      <span class="hero-photo-badge">✨ Authentic Home Feel</span>
    </div>
  </div>

  <div class="filter-pill-row">
    <a href="/listings" class="filter-pill <%= !activeCategory ? 'active' : '' %>">
      <span class="pill-icon"><i class="fa-solid fa-house-user"></i></span> All PGs
    </a>
    <a href="/listings?category=trending" class="filter-pill <%= activeCategory === 'trending' ? 'active' : '' %>">
      <span class="pill-icon"><i class="fa-solid fa-fire"></i></span> Trending
    </a>
    <a href="/listings?category=rooms" class="filter-pill <%= activeCategory === 'rooms' ? 'active' : '' %>">
      <span class="pill-icon"><i class="fa-solid fa-bed"></i></span> Rooms
    </a>
    <a href="/listings?category=cities" class="filter-pill <%= activeCategory === 'cities' ? 'active' : '' %>">
      <span class="pill-icon"><i class="fa-solid fa-city"></i></span> Iconic Cities
    </a>
    <a href="/listings?category=boys-pg" class="filter-pill <%= activeCategory === 'boys-pg' ? 'active' : '' %>">
      <span class="pill-icon"><i class="fa-solid fa-person"></i></span> Boys PG
    </a>
    <a href="/listings?category=girls-pg" class="filter-pill <%= activeCategory === 'girls-pg' ? 'active' : '' %>">
      <span class="pill-icon"><i class="fa-solid fa-person-dress"></i></span> Girls PG
    </a>
    <a href="/listings?category=co-ed" class="filter-pill <%= activeCategory === 'co-ed' ? 'active' : '' %>">
      <span class="pill-icon"><i class="fa-solid fa-people-group"></i></span> Co-ed
    </a>
    <a href="/listings?category=wifi-enabled" class="filter-pill <%= activeCategory === 'wifi-enabled' ? 'active' : '' %>">
      <span class="pill-icon"><i class="fa-solid fa-wifi"></i></span> WiFi
    </a>
    <a href="/listings?category=ac" class="filter-pill <%= activeCategory === 'ac' ? 'active' : '' %>">
      <span class="pill-icon"><i class="fa-solid fa-snowflake"></i></span> AC Rooms
    </a>
    <a href="/listings?category=food" class="filter-pill <%= activeCategory === 'food' ? 'active' : '' %>">
      <span class="pill-icon"><i class="fa-solid fa-utensils"></i></span> Food Included
    </a>
    <a href="/listings?category=attached-bath" class="filter-pill <%= activeCategory === 'attached-bath' ? 'active' : '' %>">
      <span class="pill-icon"><i class="fa-solid fa-bath"></i></span> Attached Bath
    </a>
    <a href="/listings?category=parking" class="filter-pill <%= activeCategory === 'parking' ? 'active' : '' %>">
      <span class="pill-icon"><i class="fa-solid fa-square-parking"></i></span> Parking
    </a>
  </div>

  <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3 g-4">
    <% for(let listing of allListings) { %>
      <%
        let imgUrl;
        if (listing.image && listing.image.url) {
          imgUrl = listing.image.url;
        } else {
          imgUrl = 'https://images.unsplash.com/photo-1522771739844-6a9f6d5f14af?auto=format&fit=crop&w=800&q=80';
        }
      %>
      <div class="col">
        <a href="/listings/<%= listing._id %>" class="listing-link">
          <div class="card listing-card">
            <div class="position-relative">
              <img 
                src="<%= imgUrl %>" 
                class="card-img-top" 
                alt="listing_image" 
                style="height: 14rem; object-fit: cover;"
                onerror="this.onerror=null; this.src='https://images.unsplash.com/photo-1522771739844-6a9f6d5f14af?auto=format&fit=crop&w=800&q=80';"
              >
              <% if(listing.category) { %>
                <span class="category-tag text-uppercase"><%= listing.category %></span>
              <% } %>
            </div>
            <div class="card-body">
              <b class="listing-title"><%= listing.title %></b>
              <p class="text-muted mt-1 mb-1" style="font-size:0.82rem;">
                <i class="fa-solid fa-location-dot me-1"></i><%= listing.location %>
              </p>
              <% if(listing.genderPreference || listing.sharingType) { %>
                <p class="mb-1" style="font-size:0.78rem; display:flex; gap:0.4rem; flex-wrap:wrap;">
                  <% if(listing.genderPreference) { %>
                    <span style="background:var(--primary-soft); color:var(--primary); border:1px solid rgba(138,99,255,0.3); border-radius:6px; padding:0.2rem 0.55rem; font-weight:700;">
                      <%= listing.genderPreference === 'boys' ? '👦 Boys' : listing.genderPreference === 'girls' ? '👧 Girls' : '👥 Co-ed' %>
                    </span>
                  <% } %>
                  <% if(listing.sharingType) { %>
                    <span style="background:rgba(255,255,255,0.04); color:var(--ink-soft); border:1px solid var(--border); border-radius:6px; padding:0.2rem 0.55rem; font-weight:700;">
                      <%= listing.sharingType.charAt(0).toUpperCase() + listing.sharingType.slice(1) %> Sharing
                    </span>
                  <% } %>
                </p>
              <% } %>
              <span class="listing-price">
                &#8377;<%= listing.price.toLocaleString("en-IN") %>
                <span class="unit">/month</span>
              </span>
            </div>
          </div>
        </a>
      </div>
    <% } %>
  </div>
</div>
</body>