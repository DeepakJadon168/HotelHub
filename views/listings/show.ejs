<% layout("/layouts/boilerplate") %>

<div class="container mt-4">
  <div class="row g-4">

    <div class="col-lg-7">
      <h2 class="mb-2 text-white"><%= listing.title %></h2>
      <p class="text-muted mb-3">
        <i class="fa-solid fa-location-dot text-primary me-1"></i>
        <%= listing.location %>, <%= listing.country %>
      </p>

      <div class="mb-4 rounded-4 overflow-hidden border" style="border-color: var(--border) !important;">
        <%
          let showImgUrl;
          if (listing.image && listing.image.url) {
            showImgUrl = listing.image.url;
          } else {
            showImgUrl = 'https://images.unsplash.com/photo-1522771739844-6a9f6d5f14af?auto=format&fit=crop&w=800&q=80';
          }
        %>
        <img
          src="<%= showImgUrl %>"
          alt="<%= listing.title %>"
          class="w-100 object-fit-cover"
          style="max-height: 380px; display: block;"
          onerror="this.onerror=null; this.src='https://images.unsplash.com/photo-1522771739844-6a9f6d5f14af?auto=format&fit=crop&w=800&q=80';"
        />
      </div>

      <% if(listing.genderPreference || listing.sharingType) { %>
        <div class="d-flex gap-2 flex-wrap mb-3">
          <% if(listing.genderPreference) { %>
            <span class="badge fs-6 px-3 py-2" style="background: var(--primary-soft); color: var(--primary); border: 1px solid rgba(138,99,255,0.3);">
              <%= listing.genderPreference === 'boys' ? '👦 Boys Only' : listing.genderPreference === 'girls' ? '👧 Girls Only' : '👥 Co-ed' %>
            </span>
          <% } %>
          <% if(listing.sharingType) { %>
            <span class="badge fs-6 px-3 py-2" style="background: var(--bg-elevated); color: var(--ink-soft); border: 1px solid var(--border);">
              🛏️ <%= listing.sharingType.charAt(0).toUpperCase() + listing.sharingType.slice(1) %> Sharing
            </span>
          <% } %>
        </div>
      <% } %>

      <h5 class="fw-bold text-white mb-2">Description</h5>
      <p class="text-muted"><%= listing.description %></p>

      <% if(listing.contact) { %>
        <div class="mt-3 p-3 rounded-3" style="background: var(--bg-elevated); border: 1px solid var(--border);">
          <p class="mb-0 text-muted">
            <i class="fa-solid fa-phone me-2 text-primary"></i>
            <b class="text-white">Owner Contact:</b>
            <a href="tel:<%= listing.contact %>" class="text-primary ms-2 fw-bold">
              <%= listing.contact %>
            </a>
          </p>
        </div>
      <% } %>

      <% if(listing.securityDeposit) { %>
        <div class="mt-2 p-3 rounded-3" style="background: var(--bg-elevated); border: 1px solid var(--border);">
          <p class="mb-0 text-muted">
            <i class="fa-solid fa-shield-halved me-2 text-primary"></i>
            <b class="text-white">Security Deposit:</b>
            <span class="text-primary ms-2 fw-bold">₹<%= listing.securityDeposit.toLocaleString("en-IN") %></span>
          </p>
        </div>
      <% } %>

      <p class="mt-3 text-muted">
        <b>Owner:</b>
        <span class="text-primary">@<%= listing.owner ? listing.owner.username : "Unknown" %></span>
      </p>

      <% if (currUser && listing.owner && listing.owner._id.equals(currUser._id)) { %>
        <div class="d-flex gap-3 mt-4">
          <a href="/listings/<%= listing._id %>/edit" 
             class="btn px-4 py-2 rounded-3 fw-semibold" 
             style="background: linear-gradient(135deg, var(--primary), var(--primary-dark)); color: white; border: none; box-shadow: 0 4px 15px rgba(138,99,255,0.4);">
            <i class="fa-solid fa-pen-to-square me-2"></i> Edit Listing
          </a>
          <form action="/listings/<%= listing._id %>?_method=DELETE" method="POST">
            <button class="btn px-4 py-2 rounded-3 fw-semibold"
                    style="background: linear-gradient(135deg, #ff4d4d, #c0392b); color: white; border: none; box-shadow: 0 4px 15px rgba(255,77,77,0.4);"
                    onclick="return confirm('Are you sure you want to delete this listing?')">
              <i class="fa-solid fa-trash me-2"></i> Delete Listing
            </button>
          </form>
        </div>
      <% } %>

      <hr class="my-5" style="border-color: var(--border) !important; opacity: 0.3;" />
      <h4 class="text-white mb-4">Reviews</h4>

      <% if (currUser) { %>
        <form action="/listings/<%= listing._id %>/reviews" method="POST" class="needs-validation mb-4" novalidate>
          <div class="mb-3">
            <label class="form-label fw-semibold text-muted">Rating</label>
            <fieldset class="starability-basic">
              <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating"/>
              <input type="radio" id="first-rate1" name="review[rating]" value="1" /><label for="first-rate1" title="Terrible">1 star</label>
              <input type="radio" id="first-rate2" name="review[rating]" value="2" /><label for="first-rate2" title="Not good">2 stars</label>
              <input type="radio" id="first-rate3" name="review[rating]" value="3" /><label for="first-rate3" title="Average">3 stars</label>
              <input type="radio" id="first-rate4" name="review[rating]" value="4" /><label for="first-rate4" title="Very good">4 stars</label>
              <input type="radio" id="first-rate5" name="review[rating]" value="5" /><label for="first-rate5" title="Amazing">5 stars</label>
            </fieldset>
          </div>
          <div class="mb-3">
            <label for="comment" class="form-label fw-semibold text-muted">Comment</label>
            <textarea name="review[comment]" id="comment" class="form-control text-white" rows="3" required style="background-color: var(--bg-elevated) !important; border-color: var(--border) !important;"></textarea>
            <div class="invalid-feedback">Please add a comment.</div>
          </div>
          <button class="btn px-4 py-2 rounded-3 fw-semibold" style="background: linear-gradient(135deg, var(--primary), var(--primary-dark)); color: white; border: none; box-shadow: 0 4px 15px rgba(138,99,255,0.4);">
            <i class="fa-solid fa-star me-2"></i> Submit Review
          </button>
        </form>
      <% } %>

      <div class="row g-3 mt-2">
        <% for (let review of listing.reviews) { %>
          <div class="col-md-6">
            <div class="card p-3 rounded-4" style="background-color: var(--bg-elevated) !important; border: 1px solid var(--border) !important;">
              <h6 class="fw-bold text-primary mb-1">
                @<%= review.author ? review.author.username : "Anonymous" %>
              </h6>
              <p class="starability-result my-2" data-rating="<%= review.rating %>"></p>
              <p class="text-muted small mb-3"><%= review.comment %></p>
              <% if (currUser && review.author && review.author._id.equals(currUser._id)) { %>
                <form action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" method="POST">
                  <button class="btn btn-sm px-3 rounded-3 fw-semibold"
                          style="background: rgba(255,77,77,0.1); color: #ff4d4d; border: 1px solid #ff4d4d;">
                    <i class="fa-solid fa-trash me-1"></i> Delete
                  </button>
                </form>
              <% } %>
            </div>
          </div>
        <% } %>
      </div>
    </div>

    <div class="col-lg-5">
      <div class="card p-4 rounded-4 sticky-top" style="top: 100px; z-index: 10; background-color: var(--bg-elevated) !important; border: 1px solid var(--border) !important; box-shadow: 0 12px 30px rgba(0,0,0,0.5);">
        <div class="d-flex justify-content-between align-items-baseline mb-2">
          <span class="fw-bold fs-3 text-white">₹<%= listing.price.toLocaleString("en-IN") %></span>
          <span class="text-muted">/ month</span>
        </div>

        <% if(listing.securityDeposit) { %>
          <p class="text-muted small mb-3">
            <i class="fa-solid fa-shield-halved me-1"></i>
            Security Deposit: <b class="text-white">₹<%= listing.securityDeposit.toLocaleString("en-IN") %></b>
          </p>
        <% } %>

        <% if (!currUser) { %>
          <div class="alert alert-dark text-center py-3 rounded-3" style="background-color: var(--bg) !important; border-color: var(--border) !important;">
            <a href="/login" class="fw-bold text-primary text-decoration-none">Log in</a> to book this PG space.
          </div>
        <% } else if (listing.owner && listing.owner._id.equals(currUser._id)) { %>
          <div class="alert alert-dark text-center py-3 rounded-3" style="background-color: var(--bg) !important; border-color: var(--border) !important;">
            <i class="fa-solid fa-house-user me-2 text-muted"></i> You own this PG listing.
          </div>
        <% } else { %>
          <form action="/listings/<%= listing._id %>/book" method="POST" id="bookingForm">
            <div class="mb-3">
              <label for="checkIn" class="form-label text-muted fw-semibold">Move-in Date</label>
              <input type="date" name="booking[checkIn]" id="checkIn" class="form-control text-white" required style="background-color: var(--bg) !important; border-color: var(--border) !important;" />
            </div>
            <div class="mb-3">
              <label for="checkOut" class="form-label text-muted fw-semibold">Move-out Date</label>
              <input type="date" name="booking[checkOut]" id="checkOut" class="form-control text-white" required style="background-color: var(--bg) !important; border-color: var(--border) !important;" />
            </div>

            <div id="pricePreview" class="d-none py-3 my-3 border-top" style="border-color: var(--border) !important;">
              <div class="d-flex justify-content-between align-items-center mb-1">
                <span id="monthsLabel" class="text-muted small">0 Months</span>
                <span id="totalLabel" class="fw-bold text-success fs-5">₹0</span>
              </div>
              <small id="durationWarning" class="text-danger d-none" style="font-size: 0.78rem;">
                <i class="fa-solid fa-triangle-exclamation me-1"></i> Minimum booking is 1 Month (30 Days).
              </small>
            </div>

            <button type="submit" id="bookBtn" class="btn w-100 py-2 rounded-3 fw-bold" style="background: linear-gradient(to right, var(--primary), var(--primary-dark)); color: white; border: none; box-shadow: 0 4px 15px rgba(138,99,255,0.4);">
              <i class="fa-solid fa-calendar-check me-2"></i> Book PG Now
            </button>
          </form>
        <% } %>

        <p class="text-muted text-center small mt-3 mb-0">
          No advance token adjustments applied yet.
        </p>
      </div>
    </div>

  </div>
</div>

<script>
  const pricePerMonth = <%= listing.price %>;
  const checkInEl     = document.getElementById("checkIn");
  const checkOutEl    = document.getElementById("checkOut");
  const preview       = document.getElementById("pricePreview");
  const monthsLabel   = document.getElementById("monthsLabel");
  const totalLabel    = document.getElementById("totalLabel");
  const warningEl     = document.getElementById("durationWarning");
  const bookBtn       = document.getElementById("bookBtn");

  const today = new Date().toISOString().split("T")[0];
  if (checkInEl)  checkInEl.min  = today;
  if (checkOutEl) checkOutEl.min = today;

  function updatePreview() {
    if (!checkInEl || !checkOutEl || !preview) return;
    const ci = new Date(checkInEl.value);
    const co = new Date(checkOutEl.value);
    if (checkInEl.value && checkOutEl.value && co > ci) {
      const totalDays = Math.ceil((co - ci) / (1000 * 60 * 60 * 24));
      const months = parseFloat((totalDays / 30).toFixed(1));
      const total = Math.ceil(months * pricePerMonth);
      monthsLabel.textContent = `${months} Month${months !== 1 ? "s" : ""} × ₹${pricePerMonth.toLocaleString("en-IN")}/mo`;
      totalLabel.textContent  = `₹${total.toLocaleString("en-IN")}`;
      preview.classList.remove("d-none");
      if (totalDays < 30) {
        warningEl.classList.remove("d-none");
        bookBtn.disabled = true;
        bookBtn.style.opacity = "0.6";
      } else {
        warningEl.classList.add("d-none");
        bookBtn.disabled = false;
        bookBtn.style.opacity = "1";
      }
    } else {
      preview.classList.add("d-none");
    }
  }

  if (checkInEl)  checkInEl.addEventListener("change", updatePreview);
  if (checkOutEl) checkOutEl.addEventListener("change", updatePreview);
  if (checkInEl) {
    checkInEl.addEventListener("change", () => {
      if (checkOutEl) checkOutEl.min = checkInEl.value;
    });
  }
</script>