<% layout("/layouts/boilerplate") %>

<div class="container d-flex justify-content-center align-items-center" style="min-height: 85vh;">
  <div class="card p-4 rounded-4 w-100" style="max-width: 480px; background-color: var(--bg-elevated) !important; border: 1px solid var(--border) !important; box-shadow: 0 15px 35px rgba(0,0,0,0.6);">
    
    <div class="text-center mb-4">
      <h2 class="fw-bold text-white mb-1">Create Account</h2>
      <p class="text-muted small">Join PG Wallah to find or host premium student housing</p>
    </div>

    <form action="/signup" method="POST" class="needs-validation" novalidate>
      
      <div class="mb-3">
        <label for="username" class="form-label text-muted fw-semibold small">Username</label>
        <input type="text" name="username" id="username" class="form-control text-white" placeholder="Choose a unique username" required style="background-color: var(--bg) !important; border-color: var(--border) !important;" />
        <div class="invalid-feedback">Please choose a username.</div>
      </div>

      <div class="mb-3">
        <label for="email" class="form-label text-muted fw-semibold small">Email Address</label>
        <input type="email" name="email" id="email" class="form-control text-white" placeholder="name@example.com" required style="background-color: var(--bg) !important; border-color: var(--border) !important;" />
        <div class="invalid-feedback">Please enter a valid email address.</div>
      </div>

      <div class="mb-3">
        <label for="phone" class="form-label text-muted fw-semibold small">Phone Number</label>
        <div class="input-group">
          <span class="input-group-text text-muted" style="background-color: var(--bg) !important; border-color: var(--border) !important;">+91</span>
          <input type="tel" name="phone" id="phone" class="form-control text-white" placeholder="10-digit mobile number" pattern="[6-9]{1}[0-9]{9}" required style="background-color: var(--bg) !important; border-color: var(--border) !important;" />
          <div class="invalid-feedback">Please enter a valid 10-digit phone number.</div>
        </div>
      </div>

      <div class="row g-3 mb-3">
        <div class="col-md-6">
          <label for="role" class="form-label text-muted fw-semibold small">I am a...</label>
          <select name="role" id="role" class="form-select text-white" style="background-color: var(--bg) !important; border-color: var(--border) !important;">
            <option value="student">Student</option>
            <option value="professional">Professional</option>
            <option value="owner">PG Owner</option>
          </select>
        </div>
        <div class="col-md-6">
          <label for="gender" class="form-label text-muted fw-semibold small">Gender</label>
          <select name="gender" id="gender" class="form-select text-white" required style="background-color: var(--bg) !important; border-color: var(--border) !important;">
            <option value="male">Male</option>
            <option value="female">Female</option>
            <option value="other">Other</option>
          </select>
        </div>
      </div>

      <div class="mb-3">
        <label for="organization" class="form-label text-muted fw-semibold small">College / Organization Name</label>
        <input type="text" name="organization" id="organization" class="form-control text-white" placeholder="e.g., Medi-Caps University (Optional)" style="background-color: var(--bg) !important; border-color: var(--border) !important;" />
      </div>

      <div class="mb-4">
        <label for="password" class="form-label text-muted fw-semibold small">Password</label>
        <input type="password" name="password" id="password" class="form-control text-white" placeholder="Create strong password" required style="background-color: var(--bg) !important; border-color: var(--border) !important;" />
        <div class="invalid-feedback">Please enter a password.</div>
      </div>

      <button type="submit" class="btn btn-primary w-100 py-2.5 rounded-3 fw-bold mb-3" style="background: linear-gradient(to right, var(--primary), var(--primary-dark)); border: none;">
        Sign Up
      </button>

      <p class="text-muted text-center small mb-0">
        Already have an account? <a href="/login" class="text-primary text-decoration-none fw-bold">Log in</a>
      </p>
    </form>

  </div>
</div>