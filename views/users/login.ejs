<% layout("/layouts/boilerplate") %>

<div class="container d-flex justify-content-center align-items-center" style="min-height: 70vh;">
  <div class="card p-4 rounded-4" style="width: 100%; max-width: 420px; background-color: var(--bg-elevated) !important; border: 1px solid var(--border) !important; box-shadow: 0 15px 35px rgba(0,0,0,0.6);">
    
    <div class="text-center mb-4">
      <h2 class="fw-bold text-white mb-1">Welcome Back</h2>
      <p class="text-muted small">Log in to manage or book your PG workspace</p>
    </div>

    <form action="/login" method="POST" class="needs-validation" novalidate>
      <div class="mb-3">
        <label for="username" class="form-label text-muted fw-semibold small">Username</label>
        <div class="input-group">
          <span class="input-group-text text-muted" style="background-color: var(--bg) !important; border-color: var(--border) !important;"><i class="fa-solid fa-user"></i></span>
          <input type="text" name="username" id="username" class="form-control text-white" placeholder="Enter username" required style="background-color: var(--bg) !important; border-color: var(--border) !important;" />
          <div class="invalid-feedback">Please enter your username.</div>
        </div>
      </div>

      <div class="mb-4">
        <label for="password" class="form-label text-muted fw-semibold small">Password</label>
        <div class="input-group">
          <span class="input-group-text text-muted" style="background-color: var(--bg) !important; border-color: var(--border) !important;"><i class="fa-solid fa-lock"></i></span>
          <input type="password" name="password" id="password" class="form-control text-white" placeholder="Enter password" required style="background-color: var(--bg) !important; border-color: var(--border) !important;" />
          <div class="invalid-feedback">Please enter your password.</div>
        </div>
      </div>

      <button type="submit" class="btn btn-primary w-100 py-2.5 rounded-3 fw-bold mb-3" style="background: linear-gradient(to right, var(--primary), var(--primary-dark)); border: none;">
        Log In
      </button>

      <p class="text-muted text-center small mb-0">
        Don't have an account? <a href="/signup" class="text-primary text-decoration-none fw-bold">Sign up</a>
      </p>
    </form>

  </div>
</div>